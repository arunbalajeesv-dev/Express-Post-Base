{
  "expo": {
    "name": "Sales Agent",
    "slug": "sales-agent",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": ["android"],
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a56db"
      },
      "package": "com.salesagent.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Sales Agent to access your photos for site images.",
          "cameraPermission": "Allow Sales Agent to use your camera for site photos."
        }
      ]
    ]
  }
}
